---
layout: layouts/base.njk
---

<article class="bg-white" data-sb-object-id={{ page.inputPath | sbObjectId }}>
    {% if image %}
        <figure>
            <img src="{{ image | url }}" class="w-full" eleventy:widths="960" eleventy:formats="webp" alt="{{ title }} image" data-sb-field-path="image" />
        </figure>
    {% endif %}
    <div class="px-4 pt-12 pb-16 sm:pt-16 sm:pb-24">
        <header class="max-w-2xl mx-auto mb-8 text-center">
            <h1 class="mb-2 text-3xl font-bold uppercase sm:text-4xl text-slate-800" data-sb-field-path="title">{{ title }}</h1>
            <time class="text-xs tracking-wide text-slate-400"  datetime="{{ page.date | htmlDateString }}" data-sb-field-path="date">{{ page.date | readableDate }}</time>
            {% if tags or page.tags %}
            <div class="mt-2 flex flex-wrap justify-center gap-2 text-[10px] uppercase tracking-wider">
              {% for tag in (tags or page.tags) %}
                {% if tag != "posts" and tag != "post" %}
                  <span class="px-2 py-1 bg-slate-100 text-slate-600 rounded">{{ tag }}</span>
                {% endif %}
              {% endfor %}
            </div>
            {% endif %}
        </header>
        <div class="prose prose-slate mx-auto lg:prose-lg prose-headings:font-semibold prose-p:leading-relaxed max-w-prose" data-sb-field-path="markdown_content">
            {{ content | safe }}
        </div>
    </div>
</article>
{%- if collections.posts %}
    {%- set previousPost = collections.posts | getPreviousCollectionItem %}
    {%- set nextPost = collections.posts | getNextCollectionItem %}
    {%- if nextPost or previousPost %}
        <nav class="mt-1 text-xs tracking-widest text-white uppercase bg-slate-600">
            <ul class="flex flex-wrap w-full p-4 gap-x-8 gap-y-2">
                {%- if previousPost %}
                    <li class="flex-1 w-full text-left">
                        <a class="transition hover:text-slate-200 text-nowrap" href="{{ previousPost.url }}">← Previous</a>
                    </li>
                {% endif %}
                {%- if nextPost %}
                    <li class="flex-1 w-full text-right">
                        <a class="transition hover:text-slate-200 text-nowrap" href="{{ nextPost.url }}">Next →</a>
                    </li>
                {% endif %}
            </ul>
        </nav>
    {%- endif %}
{%- endif %}