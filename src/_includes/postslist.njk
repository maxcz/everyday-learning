{%- for post in postslist | reverse %}
    <article class="relative mb-1 bg-white group ring-1 ring-slate-100 hover:ring-slate-200 transition" data-sb-object-id={{ post.inputPath | sbObjectId }}>
        {% if post.data.image %}
            <a href="{{ post.url }}">
                <img src="{{ post.data.image | url }}" class="w-full" eleventy:widths="960" eleventy:formats="webp" alt="{{ post.data.title }} image" data-sb-field-path="image">
            </a>
        {% endif %}
        <div class="px-4 pt-12 pb-16 sm:pt-16 sm:pb-24">
            <header class="max-w-2xl mx-auto mb-8 text-center">
                <h2 class="mb-2 text-3xl font-bold uppercase sm:text-4xl text-slate-800" data-sb-field-path="title">
                    <span class="group-hover:underline">{{ post.data.title }}</span>
                    <a href="{{ post.url }}" class="absolute inset-0" aria-label="{{ post.data.title }}"></a>
                </h2>
                <time class="text-xs tracking-wide text-slate-400"  datetime="{{ post.date | htmlDateString }}" data-sb-field-path="date">{{ post.date | readableDate }}</time>
                {% if post.data.tags %}
                <div class="mt-2 flex flex-wrap justify-center gap-2 text-[10px] uppercase tracking-wider">
                    {%- for tag in post.data.tags -%}
                        {%- if tag != "posts" and tag != "post" -%}
                        <span class="px-2 py-1 bg-slate-100 text-slate-600 rounded">{{ tag }}</span>
                        {%- endif -%}
                    {%- endfor -%}
                </div>
            </header>
            <div class="max-w-2xl mx-auto prose prose-slate" data-sb-field-path="markdown_content">
                {% if post.content.includes('<!--more-->') %}
                    {{ post.content.split('<!--more-->')[0] | safe }}
                    <p class="mt-12 text-center not-prose sm:mt-16">
                        <a href="{{ site.baseurl }}{{ post.url }}"
                        class="inline-flex px-6 py-4 text-xs font-medium tracking-widest no-underline uppercase transition bg-slate-100 hover:bg-slate-200">Read More</a>
                    </p>
                {% else %}
                    {{ post.content | safe }}
                {% endif %}
            </div>
        </div>
    </article>
{%- endfor %}